{"timestamp": "2026-05-10T11:59:24.895116", "level": "sql_execution", "username": "admin", "action": "execute_sql", "details": {"sql": "SELECT \n    INDUSTRY as \"行业\",\n    COUNT(*) as \"项目个数\",\n    SUM(TOTAL_BUDGET) as \"总预算\",\n    SUM(CURRENT_INVESTMENT) as \"已完成投资\",\n    AVG(TOTAL_BUDGET) as \"平均预算\",\n    MAX(TOTAL_BUDGET) as \"最大项目\",\n    MIN(TOTAL_BUDGET) as \"最小项目\"\nFROM SYSDBA.PROJECTS_INFO \nGROUP BY INDUSTRY \nORDER BY COUNT(*) DESC", "pool_name": "default", "success": true, "result": "行业,项目个数,总预算,已完成投资,平均预算,最大项目,最小项目\n新能源,1,80000000,45000000,80000000,80000000.0,80000000.0\n互联网,1,120000000,115000000,120000000,120000000.0,120000000.0\n制造业,1,200000000,80000000,200000000,200000000.0,200000000.0\n医疗健康,1,30000000,15000000,30000000,30000000.0,30000000.0\n农业,1,15000000,15200000,15000000,15000000.0,15000000.0\n交通,1,60000000,20000000,60000000,60000000.0,60000000.0\n工业4.0,1,40000000,10000000,40000000,40000000.0,40000000.0\n养老,1,25000000,18000000,25000000,25000000.0,25000000.0\n电商,1,35000000,22000000,35000000,35000000.0,35000000.0\n智慧城市,1,50000000,35000000,50000000,50000000.0,50000000.0", "execution_time_ms": 11.25955581665039}, "ip_address": null, "user_agent": null}
{"timestamp": "2026-05-10T11:59:24.919010", "level": "sql_execution", "username": "admin", "action": "execute_sql", "details": {"sql": "SELECT \n    p.INDUSTRY as \"行业\",\n    COUNT(DISTINCT p.PROJECT_ID) as \"项目数\",\n    COUNT(r.RISK_ID) as \"风险总数\",\n    SUM(CASE WHEN r.RISK_LEVEL = '高' THEN 1 ELSE 0 END) as \"高风险数\",\n    SUM(CASE WHEN r.RISK_LEVEL = '中' THEN 1 ELSE 0 END) as \"中风险数\",\n    SUM(CASE WHEN r.RISK_LEVEL = '低' THEN 1 ELSE 0 END) as \"低风险数\"\nFROM SYSDBA.PROJECTS_INFO p\nLEFT JOIN SYSDBA.PROJECTS_RISK r ON p.PROJECT_ID = r.PROJECT_ID\nGROUP BY p.INDUSTRY\nORDER BY COUNT(DISTINCT p.PROJECT_ID) DESC", "pool_name": "default", "success": true, "result": "行业,项目数,风险总数,高风险数,中风险数,低风险数\n工业4.0,1,1,1,0,0\n互联网,1,1,0,1,0\n交通,1,1,1,0,0\n农业,1,1,0,0,1\n新能源,1,1,1,0,0\n养老,1,1,0,1,0\n医疗健康,1,1,0,0,1\n制造业,1,1,0,1,0\n智慧城市,1,1,1,0,0\n电商,1,1,0,1,0", "execution_time_ms": 9.357452392578125}, "ip_address": null, "user_agent": null}

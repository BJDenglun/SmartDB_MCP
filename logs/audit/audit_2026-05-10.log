{"timestamp": "2026-05-10T00:29:28.983429", "level": "sql_execution", "username": "admin", "action": "execute_sql", "details": {"sql": "INSERT INTO SYSDBA.PROJECTS_RISK VALUES \n('R001', 'P001', '技术风险', '智慧城市平台兼容性风险', '高', '中等', '项目级', '监控中', '多系统集成存在兼容性问题', '进行兼容性测试，建立统一接口标准', '张伟', '2024-02-01', '2024-12-31', NULL, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),\n('R002', 'P002', '资金风险', '储能设备采购资金紧张', '高', '高', '公司级', '处理中', '核心设备供应商要求预付款，资金周转压力', '申请银行贷款，寻求战略投资者', '李明', '2024-03-15', '2024-09-30', NULL, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),\n('R003', 'P003', '进度风险', '机房装修工期延误', '中', '低', '项目级', '已解决', '装修单位人员不足，导致工期延误2个月', '更换装修单位，增加施工人员', '王芳', '2023-09-01', '2024-03-31', '2024-03-28', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),\n('R004', 'P004', '市场风险', '原材料价格上涨', '中', '中等', '项目级', '监控中', '钢材价格同比上涨15%，影响建设成本', '提前锁定供应商价格，备选供应商', '赵强', '2024-04-01', NULL, NULL, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),\n('R005', 'P007', '技术风险', '交通信号AI算法准确率不足', '高', '高', '项目级', '处理中', 'AI信号优化算法在城市复杂路况下准确率仅75%', '引入第三方算法团队，优化模型', '陈刚', '2024-06-01', '2025-06-30', NULL, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),\n('R006', 'P009', '合规风险', '养老机构资质申请延迟', '中', '低', '项目级', '已解决', '部分资质审批流程比预期长', '与主管部门积极沟通，加快审批', '刘华', '2024-02-01', '2024-06-30', '2024-06-25', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),\n('R007', 'P008', '市场风险', '中小企业用户推广困难', '高', '中等', '项目级', '处理中', '目标客户对工业互联网平台认知度低', '开展免费试用，举办行业推广会', '周杰', '2024-07-01', '2025-03-31', NULL, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),\n('R008', 'P005', '政策风险', '医疗数据合规政策变化', '低', '低', '项目级', '已解决', '医疗数据使用政策调整', '按新政策调整数据使用方案', '吴静', '2024-05-01', '2024-08-31', '2024-08-20', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),\n('R009', 'P010', '运营风险', '跨境物流时效不稳定', '中', '中等', '项目级', '监控中', '国际航班减少导致物流时效波动', '建立多渠道物流方案', '郑海', '2024-04-15', NULL, NULL, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP),\n('R010', 'P006', '进度风险', '农产品追溯系统开发延期', '低', '低', '项目级', '已解决', '系统开发遇到技术难题', '引入外部技术团队协助', '孙丽', '2023-10-01', '2024-03-31', '2024-03-25', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)", "pool_name